generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Place {
  id                 String        @id @default(uuid())
  address            String?
  cep                String?
  city               String?
  coverImage         String?
  description        String?
  distance           String?
  email              String?
  emoji              String        @default("📍")
  featured           Boolean       @default(false)
  images             String?
  instagram          String?
  name               String
  phone              String?
  plan               String        @default("free")
  premium            Boolean       @default(false)
  rating             Float?
  reviews            String?
  state              String?
  tags               String?
  type               String        @default("Lugar")
  website            String?
  createdAt          DateTime      @default(now())
  editorialSummary   String?
  googlePlaceId      String?       @unique
  internationalPhone String?
  priceLevel         Int?
  types              String[]
  updatedAt          DateTime      @default(now()) @updatedAt
  userRatingsTotal   Int?          @default(0)
  profileImage       String?
  category           String?
  last_updated       DateTime?     @default(now())
  opening_hours      String?
  osm_id             String?       @unique
  photo_url          String?
  activities         Activity[]
  checkins           CheckIn[]
  favorites          Favorite[]
  menuLink           MenuLink?
  openingHours       OpeningHours?
  photos             Photo[]
  googleReviews      Review[]
  routePlaces        RoutePlace[]
  comments           Comment[]
}

model Photo {
  id               String   @id @default(uuid())
  url              String
  googleRef        String?
  htmlAttributions String[]
  placeId          String
  place            Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Review {
  id                  String  @id @default(uuid())
  authorName          String
  authorPhotoUrl      String?
  rating              Float
  text                String
  relativePublishTime String?
  placeId             String
  userId              String?
  place               Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user                User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OpeningHours {
  id          String   @id @default(uuid())
  weekdayText String[]
  openNow     Boolean  @default(false)
  placeId     String   @unique
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model MenuLink {
  id      String @id @default(uuid())
  url     String
  placeId String @unique
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model ImportJob {
  id          String   @id @default(uuid())
  city        String
  category    String
  placesCount Int
  status      String   @default("COMPLETED")
  createdAt   DateTime @default(now())
}

model Event {
  id       String  @id @default(uuid())
  name     String
  emoji    String
  type     String
  gradient String
  date     String
  time     String
  loc      String
  featured Boolean @default(false)
}

model Favorite {
  id         String   @id @default(uuid())
  note       String?
  collection String   @default("Todos")
  createdAt  DateTime @default(now())
  placeId    String
  userId     String?
  place      Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
}

model User {
  id              String            @id @default(uuid())
  name            String
  email           String            @unique
  password        String
  role            String            @default("user")
  avatar          String?
  level           Int               @default(1)
  xp              Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  activities      Activity[]
  checkins        CheckIn[]
  DeveloperApiKey DeveloperApiKey[]
  favorites       Favorite[]
  guideProfile    GuideProfile?
  reservations    Reservation[]     @relation("CustomerReservations")
  reviews         Review[]
  tourReviews     TourReview[]
  comments        Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  rating    Float
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  placeId   String?
  place     Place?   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  
  cityId    String?
  city      City?    @relation(fields: [cityId], references: [id], onDelete: Cascade)
  
  guideId   String?
  guide     GuideProfile? @relation(fields: [guideId], references: [id], onDelete: Cascade)
}

model CheckIn {
  id        String   @id @default(uuid())
  placeId   String
  userId    String
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id          String   @id @default(uuid())
  userId      String
  type        String
  placeId     String?
  description String?
  xpEarned    Int      @default(0)
  createdAt   DateTime @default(now())
  place       Place?   @relation(fields: [placeId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UpdateLog {
  id        String   @id @default(uuid())
  version   String
  fileName  String
  status    String
  duration  String?
  logOutput String?
  createdAt DateTime @default(now())
}

model GuideProfile {
  id             String        @id @default(uuid())
  userId         String        @unique
  bio            String?
  languages      String[]
  pixKey         String?
  status         String        @default("PENDING")
  commissionRate Float         @default(0.15)
  documents      String[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  rating         Float?
  totalKm        Float?        @default(0)
  customColors   String?
  customDomain   String?
  customFont     String?
  customSettings String?
  featured       Boolean       @default(false)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  Subscription   Subscription?
  packages       TourPackage[]
  routes         TourRoute[]
  plan           String        @default("free")
  packagesSold   Int           @default(0)
  comments       Comment[]
}

model TourRoute {
  id              String        @id @default(uuid())
  guideId         String
  title           String
  description     String?
  durationMinutes Int?
  status          String        @default("DRAFT")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  places          RoutePlace[]
  guide           GuideProfile  @relation(fields: [guideId], references: [id], onDelete: Cascade)
  packages        TourPackage[] @relation("TourPackageToTourRoute")
}

model RoutePlace {
  id      String    @id @default(uuid())
  routeId String
  placeId String
  order   Int       @default(0)
  notes   String?
  place   Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  route   TourRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([routeId, placeId])
}

model TourPackage {
  id           String        @id @default(uuid())
  guideId      String
  title        String
  description  String?
  price        Float
  durationDays Int           @default(1)
  maxPeople    Int           @default(10)
  minPeople    Int           @default(1)
  status       String        @default("DRAFT")
  images       String[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
  guide        GuideProfile  @relation(fields: [guideId], references: [id], onDelete: Cascade)
  reviews      TourReview[]
  routes       TourRoute[]   @relation("TourPackageToTourRoute")
}

model Reservation {
  id         String      @id @default(uuid())
  customerId String
  packageId  String
  date       DateTime
  status     String      @default("PENDING")
  totalPrice Float
  guests     Int         @default(1)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  customer   User        @relation("CustomerReservations", fields: [customerId], references: [id], onDelete: Cascade)
  package    TourPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  review     TourReview?
}

model TourReview {
  id            String      @id @default(uuid())
  reservationId String      @unique
  packageId     String
  customerId    String
  rating        Float
  comment       String?
  createdAt     DateTime    @default(now())
  customer      User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  package       TourPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String   @id @default(uuid())
  provider    String   @unique
  key         String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiRoute {
  id          String   @id @default(uuid())
  name        String   @unique
  url         String
  method      String   @default("GET")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model City {
  id            String   @id @default(uuid())
  name          String
  state         String?
  description   String?
  profileImage  String?
  coverImage    String?
  galleryImages String[]
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  comments      Comment[]
}

model Plugin {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  version     String   @default("1.0.0")
  author      String?
  isActive    Boolean  @default(false)
  manifest    String?
  codeHtml    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  settings    String?
}

model Coupon {
  id              String         @id
  code            String         @unique
  discountPercent Float?
  discountAmount  Float?
  maxUses         Int?
  usedCount       Int            @default(0)
  expiresAt       DateTime?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  Subscription    Subscription[]
}

model DeveloperApiKey {
  id        String   @id
  userId    String
  key       String   @unique
  name      String   @default("Default Key")
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Plan {
  id                      String         @id
  name                    String
  description             String?
  price                   Float
  interval                String         @default("monthly")
  trialDays               Int            @default(0)
  features                String[]
  isActive                Boolean        @default(true)
  externalPriceId         String?
  provider                String?
  maxTours                Int            @default(0)
  maxFeaturedTours        Int            @default(0)
  premiumBadge            Boolean        @default(false)
  priorityVerification    Boolean        @default(false)
  supportWhatsapp247      Boolean        @default(false)
  supportEmail            Boolean        @default(false)
  vipProspector           Boolean        @default(false)
  advancedAnalytics       Boolean        @default(false)
  cityMapHighlight        Boolean        @default(false)
  touristChat             Boolean        @default(false)
  vipProfileCustomization Boolean        @default(false)
  publicProfile           Boolean        @default(true)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime
  Subscription            Subscription[]
}

model Subscription {
  id                     String       @id
  guideId                String       @unique
  planId                 String
  status                 String       @default("active")
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean      @default(false)
  couponId               String?
  externalSubscriptionId String?      @unique
  paymentStatus          String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime
  Coupon                 Coupon?      @relation(fields: [couponId], references: [id])
  GuideProfile           GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  Plan                   Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
}
