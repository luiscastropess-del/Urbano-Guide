generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
}

model Place {
  id                 String   @id @default(uuid())
  googlePlaceId      String?  @unique // Chave para evitar duplicatas do Google
  name               String
  emoji              String   @default("📍")
  rating             Float?
  userRatingsTotal   Int?     @default(0)
  priceLevel         Int?
  reviews            String? // Legado
  distance           String? // Legado
  type               String   @default("Lugar")
  types              String[] // Suportado no Postgres: Array com categorias exatas (restaurant, cafe)
  featured           Boolean  @default(false)
  premium            Boolean  @default(false)
  description        String?
  editorialSummary   String? // Descrição feita por editores do Google
  tags               String?
  address            String?
  city               String?
  state              String?
  cep                String?
  phone              String?
  internationalPhone String?
  instagram          String?
  website            String?
  email              String?
  plan               String   @default("free")
  coverImage         String?
  profileImage       String?
  images             String? // Legado

  // Novos Relacionamentos
  photos        Photo[]
  googleReviews Review[]
  openingHours  OpeningHours?
  menuLink      MenuLink?
  favorites     Favorite[]
  checkins      CheckIn[]
  activities    Activity[]
  routePlaces   RoutePlace[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Photo {
  id               String   @id @default(uuid())
  url              String // URL pública do Google Cloud Storage
  googleRef        String? // Referência original para checagem
  htmlAttributions String[] // Créditos exigidos pelos direitos autorais
  placeId          String
  place            Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Review {
  id                  String  @id @default(uuid())
  authorName          String
  authorPhotoUrl      String?
  rating              Float
  text                String
  relativePublishTime String?
  placeId             String
  place               Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId              String?
  user                User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OpeningHours {
  id          String   @id @default(uuid())
  weekdayText String[] // Array do tipo ["Seg: 09:00 - 18:00", ...]
  openNow     Boolean  @default(false)
  placeId     String   @unique
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model MenuLink {
  id      String @id @default(uuid())
  url     String
  placeId String @unique
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model ImportJob {
  id          String   @id @default(uuid())
  city        String
  category    String
  placesCount Int
  status      String   @default("COMPLETED")
  createdAt   DateTime @default(now())
}

model Event {
  id       String  @id @default(uuid())
  name     String
  emoji    String
  type     String
  gradient String
  date     String
  time     String
  loc      String
  featured Boolean @default(false)
}

model Favorite {
  id         String   @id @default(uuid())
  placeId    String
  place      Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection String   @default("Todos")
  createdAt  DateTime @default(now())
  note       String?

  @@unique([placeId, userId])
}

model User {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  password   String
  role       String     @default("user") // "admin", "guide", "user"
  avatar     String?
  level      Int        @default(1)
  xp         Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  favorites  Favorite[]
  reviews    Review[]
  checkins   CheckIn[]
  activities Activity[]

  guideProfile GuideProfile?
  reservations Reservation[] @relation("CustomerReservations")
  tourReviews  TourReview[]
}

model CheckIn {
  id        String   @id @default(uuid())
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Activity {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // "CHECK_IN", "FAVORITE", "REVIEW", "LEVEL_UP", "JOIN"
  placeId     String?
  place       Place?   @relation(fields: [placeId], references: [id], onDelete: SetNull)
  description String?
  xpEarned    Int      @default(0)
  createdAt   DateTime @default(now())
}

model UpdateLog {
  id        String   @id @default(uuid())
  version   String
  fileName  String
  status    String // "SUCCESS", "FAILED", "ROLLBACK"
  duration  String?
  logOutput String?  @db.Text
  createdAt DateTime @default(now())
}

model GuideProfile {
  id             String        @id @default(uuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio            String?       @db.Text
  languages      String[]
  pixKey         String?
  status         String        @default("PENDING") // PENDING, APPROVED, REJECTED, BLOCKED
  commissionRate Float         @default(0.15) // 15% default fee
  documents      String[] // URLs to documents
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  routes         TourRoute[]
  packages       TourPackage[]
}

model TourRoute {
  id              String       @id @default(uuid())
  guideId         String
  guide           GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  title           String
  description     String?      @db.Text
  durationMinutes Int?
  status          String       @default("DRAFT") // DRAFT, PUBLISHED
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  places   RoutePlace[]
  packages TourPackage[]
}

model RoutePlace {
  id      String    @id @default(uuid())
  routeId String
  route   TourRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  placeId String
  place   Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  order   Int       @default(0) // Order in the route
  notes   String?   @db.Text // Guide notes for this specific place

  @@unique([routeId, placeId])
}

model TourPackage {
  id           String       @id @default(uuid())
  guideId      String
  guide        GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  title        String
  description  String?      @db.Text
  price        Float
  durationDays Int          @default(1)
  maxPeople    Int          @default(10)
  minPeople    Int          @default(1)
  status       String       @default("DRAFT") // DRAFT, PUBLISHED
  images       String[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  routes       TourRoute[]
  reservations Reservation[]
  reviews      TourReview[]
}

model Reservation {
  id         String      @id @default(uuid())
  customerId String
  customer   User        @relation("CustomerReservations", fields: [customerId], references: [id], onDelete: Cascade)
  packageId  String
  package    TourPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  date       DateTime
  status     String      @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  totalPrice Float
  guests     Int         @default(1)
  notes      String?     @db.Text
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  review TourReview?
}

model TourReview {
  id            String      @id @default(uuid())
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  packageId     String
  package       TourPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  customerId    String
  customer      User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rating        Float
  comment       String?     @db.Text
  createdAt     DateTime    @default(now())
}

model ApiKey {
  id          String   @id @default(uuid())
  provider    String   @unique // e.g., "GOOGLE_MAPS", "OPENROUTER", "STRIPE"
  key         String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiRoute {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "PROSPECT_API"
  url         String
  method      String   @default("GET")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Plugin {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  version     String   @default("1.0.0")
  author      String?
  isActive    Boolean  @default(false)
  manifest    String?  @db.Text // JSON config
  codeHtml    String?  @db.Text // Iframe code
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
